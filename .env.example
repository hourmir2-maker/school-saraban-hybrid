# ===================================
# 🏫 School Saraban Hybrid - Environment Variables
# ===================================
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
# cp .env.example .env

# --- Supabase (จำเป็นต้องกรอก) ---
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase Service Role (สำหรับ API Server เท่านั้น - อย่าใช้ใน Frontend!) ---
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- ข้อมูลโรงเรียน ---
VITE_SCHOOL_NAME=ชื่อโรงเรียน
VITE_SCHOOL_LOGO_PATH=/logo.png

# --- Google Apps Script (สำหรับอัปโหลดไฟล์) ---
VITE_GAS_URL=your_google_apps_script_url

# --- Vercel Deployment ---
VITE_VERCEL_URL=https://your-app.vercel.app

# --- Super Admin ---
VITE_SUPER_ADMIN_EMAIL=admin@example.com

# --- App Version ---
VITE_APP_VERSION=1.1.14

# --- LINE Bot (Server-side only) ---
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
